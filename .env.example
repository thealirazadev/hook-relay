# Application name shown in logs and the dashboard title.
APP_NAME=hook-relay
# Environment: local, production.
APP_ENV=local
# Generate with: php artisan key:generate (also encrypts stored signing secrets).
APP_KEY=
# Must be false outside local.
APP_DEBUG=true
# Public base URL; ingest URLs shown in the dashboard are built from this.
APP_URL=http://localhost:8000

# Log channel and minimum level.
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Local dev uses SQLite (touch database/database.sqlite first).
DB_CONNECTION=sqlite
# Production uses MySQL; uncomment and fill:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hook_relay
# DB_USERNAME=hook_relay
# DB_PASSWORD=changeme

# Database-backed session, queue, and cache: no Redis required.
SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# Max accepted webhook payload size in KB; larger bodies get 413.
INGEST_MAX_BODY_KB=512
# Outbound delivery timeout per attempt, in seconds.
DELIVERY_TIMEOUT_SECONDS=10
# Delivery attempts before a delivery is marked dead.
DELIVERY_MAX_ATTEMPTS=8
# Days to keep events (and their deliveries) before pruning.
RETENTION_DAYS=30
